{
  "name": "@tuckmark/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build": "node ../../scripts/build-detonger-wasm.mjs --release",
    "wasm:build:dev": "node ../../scripts/build-detonger-wasm.mjs --dev",
    "prebuild": "bun run wasm:build",
    "build": "bun run typecheck && vite build",
    "build:pages": "bun run typecheck && TUCKMARK_WEB_SURFACE=browser-static vite build",
    "build:storybook": "storybook build --output-dir ../../work/storybook-web",
    "predev": "bun run wasm:build:dev",
    "dev": "vite",
    "prestorybook": "bun run wasm:build:dev",
    "storybook": "storybook dev --port 6006",
    "pretest": "bun run wasm:build:dev",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:sync": "playwright test -c playwright.config.sync.ts",
    "pretypecheck": "bun run wasm:build:dev",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/noto-serif-sc": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsbarcode": "^3.12.3",
    "konva": "^10.3.0",
    "lpapi-ble": "1.7.260605",
    "lucide-react": "^1.21.0",
    "pngjs": "7.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "tw-animate-css": "^1.4.0"
  }
}
